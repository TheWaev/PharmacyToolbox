# Supabase auth — copy to `.env` for local dev, and set the same vars in your
# host's build environment (e.g. Cloudflare Pages). Both values are PUBLIC
# (the anon key is designed to be exposed in the browser; row-level security
# protects data). They are baked in at build time by Vite.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# DEV ONLY: set to "true" to skip the login gate while working locally.
# Ignored in production builds.
VITE_AUTH_DEV_BYPASS=false
